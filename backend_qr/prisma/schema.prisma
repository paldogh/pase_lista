generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}



model Alumno {
  id        String   @id @default(uuid())
  nombre    String
  apellido  String
  correo    String   @unique

  asistencias Asistencia[]
}

model Maestro {
  id        String   @id @default(uuid())
  nombre    String
  apellido  String
}

model Carrera {
  id      String   @id @default(uuid())
  nombre  String
}

model Asistencia {
  id        String   @id @default(uuid())
  estado    String
  fecha     DateTime @default(now())

  alumnoId  String
  alumno    Alumno @relation(fields: [alumnoId], references: [id])
}